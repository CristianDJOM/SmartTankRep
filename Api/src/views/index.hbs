<style>
  @import url('https://fonts.googleapis.com/css?family=Playfair+Display|Abel');
 
  * { 
    padding: 0; 
    margin: 0;
    box-sizing: border-box; 
  }

  body {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    background-color: #E3FDF5;
  }

  .form1 { 
    width: 390px; 
    min-height: 500px; 
    border-radius: 5px; 
    box-shadow: 0 9px 50px rgba(20, 67, 75, 0.31); 
    padding: 2%; 
    background-image: linear-gradient(-225deg, #E3FDF5 50%, #93dbff 50%);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  header { 
    text-align: center;
  }

  header h2 {
    font-size: 2rem;
    font-family: 'Playfair Display', serif;
    color: #3e403f;
  }

  header p {
    letter-spacing: 0.05em;
  }

  .input-item {
    background: #fff;
    color: #333;
    padding: 14.5px 9px;
    border-radius: 5px 0px 0px 5px;
  }

  .form-input {
    width: 240px;
    height: 50px;
    padding: 15px;
    font-size: 16px;
    font-family: 'Abel', sans-serif;
    color: #5E6472;
    outline: none;
    border: none;
    border-radius: 0px 5px 5px 0px;
  }

  .button1 {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 280px;
    height: 50px;
    background: #026292;
    border-radius: 5px;
    border: none;
    cursor: pointer;
    text-align: center;
    transition: all 0.2s linear;
    margin-top: 20px;
  }

  .button1 p {
    color: white;
    font-size: 1.2rem;
    font-family: 'Abel', sans-serif;
    margin: 0;
  }

  .button1:hover {
    transform: translateY(3px);
  }
</style>

<div class="overlay">
  <form class="form1" action="/Mis/Pagos" method="POST">
    <header class="head-form">
      <h2>Consulta de Pagos</h2>
      <p>Ingresa tu número de identificación para ver tus pagos realizados.</p>
      <img class="bordes" src="/assets/img/Logo.png" alt="logo" />
    </header>
    <br />
    <div class="field-set">
      <span class="input-item">
        <i class="fa fa-id-card"></i>
      </span>
      <input
        class="form-input"
        id="identificacion"
        type="number"
        name="identificacion"
        placeholder="Identificación"
      />
      <br />
      <button class="log-in button1">
        <p>Consultar</p>
      </button>
    </div>
  </form>
</div>
